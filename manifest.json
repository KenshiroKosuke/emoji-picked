{
  "manifest_version": 3,
  "name": "Emoji Packed",
  "version": "1.0",
  "permissions": ["downloads", "activeTab"],
  "host_permissions": ["*://*.googleusercontent.com/*"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Emoji Packed",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"], 
      "js": ["content.js"]
    }
  ]
}